# =========================
# ParkShare Root .gitignore
# =========================

# --- Node.js ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Environment Variables / Secrets ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem

# --- Firebase ---
**/google-services.json
**/GoogleService-Info.plist
**/firebase_service_account*.json

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
venv/
.venv/

# --- Flutter / Dart ---
frontend/.dart_tool/
frontend/build/
frontend/.flutter-plugins
frontend/.flutter-plugins-dependencies
frontend/.packages
frontend/pubspec.lock

# --- Android ---
frontend/android/.gradle/
frontend/android/app/build/
frontend/android/build/
frontend/android/local.properties
*.apk
*.aab

# --- iOS ---
frontend/ios/Pods/
frontend/ios/.symlinks/
frontend/ios/Flutter/Flutter.framework
frontend/ios/Flutter/Generated.xcconfig
frontend/ios/Flutter/app.flx
frontend/ios/Flutter/flutter_assets/
frontend/ios/ServiceDefinitions.json
frontend/ios/Runner/GeneratedPluginRegistrant.*

# --- Admin Panel (Vite/React) ---
admin/node_modules/
admin/dist/
admin/.env

# --- AI Service ---
ai/__pycache__/
ai/venv/
ai/.env

# --- IDE ---
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
